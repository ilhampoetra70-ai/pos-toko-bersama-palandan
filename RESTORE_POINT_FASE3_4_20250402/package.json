{
  "name": "pos-cashier",
  "version": "1.0.0",
  "description": "POS Cashier Desktop Application",
  "main": "electron/main.js",
  "author": "POS Cashier",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:6173 && electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "build:portable": "node scripts/build_all.js && npm run build:renderer && electron-builder --win portable",
    "build:dir": "npm run build:renderer && electron-builder --dir",
    "postbuild:dir": "node scripts/fix-icon.js \"TOKO BERSAMA BARU/win-unpacked\"",
    "fix:icon": "node scripts/fix-icon.js",
    "fix:icon:toko": "node scripts/fix-icon.js \"TOKO BERSAMA BARU/win-unpacked\"",
    "build:all": "node scripts/build_all.js && npm run build:renderer && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.poscashier.app",
    "productName": "Toko Bersama",
    "directories": {
      "output": "TOKO BERSAMA BARU"
    },
    "files": [
      "electron/**/*",
      "dist-renderer/**/*",
      "price-checker/**/*",
      "mobile-admin-dist/**/*",
      "node_modules/**/*",
      "!node_modules/**/README*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/test/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/*.md",
      "!node_modules/@node-llama-cpp/win-x64-cuda-ext/**/*",
      "!node_modules/@node-llama-cpp/win-x64-cuda/**/*",
      "!node_modules/@node-llama-cpp/win-x64-vulkan/**/*",
      "!node_modules/@node-llama-cpp/win-arm64/**/*"
    ],
    "extraResources": [
      {
        "from": "cloudflared.exe",
        "to": "cloudflare/cloudflared.exe"
      },
      {
        "from": "start_tunnel.bat",
        "to": "cloudflare/start_tunnel.bat"
      },
      {
        "from": "setup_cloudflare.bat",
        "to": "cloudflare/setup_cloudflare.bat"
      },
      {
        "from": "start_all_services.bat",
        "to": "cloudflare/start_all_services.bat"
      }
    ],
    "win": {
      "icon": "assets/tb_logo_1771832778678.png",
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}",
      "requestExecutionLevel": "admin"
    },
    "asar": true,
    "asarUnpack": [
      "price-checker/**/*",
      "mobile-admin-dist/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/node-llama-cpp/**/*",
      "node_modules/@node-llama-cpp/**/*"
    ],
    "compression": "maximum"
  },
  "dependencies": {
    "@ericblade/quagga2": "^1.8.4",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.18",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "jsbarcode": "^3.11.6",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.563.0",
    "node-llama-cpp": "^3.16.2",
    "otplib": "^11.0.1",
    "qrcode": "^1.5.4",
    "recharts": "^3.7.0",
    "simple-keyboard": "^3.8.111",
    "tailwind-merge": "^3.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "axios": "^1.14.0",
    "concurrently": "^9.1.0",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.17",
    "@tanstack/react-query-devtools": "^5.91.3",
    "typescript": "^5.9.3",
    "vite": "^6.0.5",
    "wait-on": "^9.0.4"
  }
}
